# Copy these variables into Render environment settings for backend service.
SPRING_DATASOURCE_URL=jdbc:mysql://<host>:3306/<database>?createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=<db_user>
SPRING_DATASOURCE_PASSWORD=<db_password>

SPRING_MAIL_USERNAME=<gmail_address>
SPRING_MAIL_PASSWORD=<gmail_app_password>

APP_JWT_SECRET=<long_random_secret>
APP_BASE_URL=https://<your-backend>.onrender.com
APP_FRONTEND_URL=https://<your-frontend>.onrender.com
APP_CORS_ALLOWED_ORIGINS=https://<your-frontend>.onrender.com,http://localhost:5173,http://localhost:3000,http://localhost:5174
